{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "ignorePatterns": ["node_modules", "dist", "out", "coverage"],
    "sortImports": {
        "order": "asc",
        "ignoreCase": true,
        "newlinesBetween": true,
        "internalPattern": ["@blockdaemon/*"],
        "customGroups": [
            {
                "groupName": "package",
                "elementNamePattern": ["@package/**"]
            }
        ],
        "groups": [
            ["builtin", "type-builtin"],
            ["external", "type-external"],
            "package",
            ["internal", "type-internal"],
            ["parent", "sibling", "index", "type-parent", "type-sibling", "type-index"]
        ]
    },
    "sortPackageJson": {
        "sortScripts": true
    }
}
