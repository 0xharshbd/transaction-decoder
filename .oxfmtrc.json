{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "ignorePatterns": ["node_modules", "dist", "out", "coverage"],
    "sortImports": {
        "order": "asc",
        "ignoreCase": true,
        "newlinesBetween": true,
        "groups": ["builtin", "external", "internal", "parent", "sibling", "index", "type"]
    },
    "sortPackageJson": {
        "sortScripts": true
    }
}
